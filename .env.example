# Application
APP_NAME=Auto Invest Server
APP_DEBUG=true
APP_ENV=dev
HOST=127.0.0.1
PORT=8000

# Default symbols
# Keep DEFAULT_SYMBOL=AAPL for legacy Alpaca compatibility.
# Korean symbols must remain strings so leading zeroes are preserved.
DEFAULT_SYMBOL=AAPL
DEFAULT_US_SYMBOL=AAPL
DEFAULT_KR_SYMBOL=005930

# Database
DATABASE_URL=sqlite:///./auto_invest.db

# Runtime safety defaults
DRY_RUN=true
KILL_SWITCH=false
BROKER_PROVIDER=alpaca

# Alpaca paper trading placeholders
ALPACA_API_KEY=replace-with-paper-key
ALPACA_SECRET_KEY=replace-with-paper-secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# KIS broker configuration placeholders
KIS_ENABLED=false
KIS_ENV=paper
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=01
KIS_HTS_ID=
KIS_BASE_URL=
KIS_WS_URL=
KIS_ACCESS_TOKEN=
KIS_APPROVAL_KEY=
KIS_REAL_ORDER_ENABLED=false
KIS_MAX_MANUAL_ORDER_QTY=1
KIS_MAX_MANUAL_ORDER_AMOUNT_KRW=100000
KIS_REQUIRE_CONFIRMATION=true
KIS_CONFIRMATION_PHRASE=I UNDERSTAND THIS WILL PLACE A REAL KIS ORDER

# KIS live automation defaults
KIS_LIVE_AUTO_SELL_ENABLED=false
KIS_LIVE_AUTO_BUY_ENABLED=false
KIS_LIMITED_AUTO_SELL_ENABLED=false
KIS_LIMITED_AUTO_STOP_LOSS_ENABLED=false
KIS_LIMITED_AUTO_TAKE_PROFIT_ENABLED=false
KIS_LIMITED_AUTO_BUY_ENABLED=false

# KIS scheduler defaults
KIS_SCHEDULER_ENABLED=false
KIS_SCHEDULER_DRY_RUN=true
KIS_SCHEDULER_ALLOW_REAL_ORDERS=false
KIS_SCHEDULER_SELL_ENABLED=false
KIS_SCHEDULER_BUY_ENABLED=false
KR_SCHEDULER_ENABLED=false
KR_SCHEDULER_ALLOW_REAL_ORDERS=false

# OpenAI placeholders
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=medium

# Config paths
REFERENCE_SITES_CONFIG_PATH=config/reference_sites.yaml
EVENT_SOURCES_CONFIG_PATH=config/event_sources.yaml
WATCHLIST_CONFIG_PATH=config/watchlist.yaml
MARKET_PROFILES_CONFIG_PATH=config/market_profiles.yaml
MARKET_SESSIONS_CONFIG_PATH=config/market_sessions.yaml
MARKET_HOLIDAYS_CONFIG_PATH=config/market_holidays.yaml
